---
import config from '../../gallery.config';
import { withBase } from '../lib/url';
import { navPages } from '../lib/pages';
import '../styles/tokens.css';
import '../styles/fonts.css';
import '../styles/shell.css';
import '../styles/gallery.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import KebabNav from '../components/KebabNav.astro';
import atkinsonUrl from '../assets/fonts/AtkinsonHyperlegibleNext-VariableFont_wght.woff2?url';

interface Props {
  title?: string;
  description?: string;
  /** Right-side counter text, e.g. "24 photos". */
  count?: string;
}

const { title, description, count } = Astro.props;
const pageTitle = title ? `${title} — ${config.title}` : config.title;
const chrome = config.chrome;
/* Chrome menu = markdown entry pages (src/content/pages/, nav: true)
   followed by the manual links from gallery.config nav. */
const pageLinks = (await navPages()).map((p) => ({
  label: p.data.navLabel ?? p.data.title.toLowerCase(),
  href: withBase(`${p.id}/`),
  external: false,
}));
const configLinks = (config.nav ?? []).map((link) => {
  // Any scheme (https:, mailto:, tel:, …) is left untouched; only http(s)
  // gets the new-tab treatment; everything else is an internal path.
  const hasScheme = /^[a-z][a-z0-9+.-]*:/i.test(link.href);
  const external = /^https?:\/\//.test(link.href);
  return { ...link, external, href: hasScheme ? link.href : withBase(link.href) };
});
const nav = [...pageLinks, ...configLinks];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description ?? config.description} />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <link rel="preload" href={atkinsonUrl} as="font" type="font/woff2" crossorigin />
    <script is:inline>
      /* Theme init — runs before paint so there is no flash. */
      (function () {
        var saved = localStorage.getItem('theme');
        var dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute(
          'data-theme',
          saved === 'light' || saved === 'dark' ? saved : dark ? 'dark' : 'light'
        );
      })();
    </script>
  </head>
  <body data-chrome={chrome} data-mobile-nav={config.mobileNav ?? 'kebab'}>
    <div class="app-frame">
      {
        chrome === 'frame' && (
          <>
            <span class="float-chip float-chip--tl">
              <a class="chrome-title" href={withBase("")}>
                <span class="chrome-mark">▧</span> {config.title}
              </a>
              <nav class="chrome-nav">
                {nav.map((l) => (
                  <a href={l.href} target={l.external ? '_blank' : undefined} rel={l.external ? 'noopener' : undefined}>
                    {l.label}
                  </a>
                ))}
              </nav>
            </span>
            <span class="float-chip float-chip--tr">
              <ThemeToggle />
              <KebabNav nav={nav} />
            </span>
          </>
        )
      }
      <div class="site">
        {
          chrome === 'header' && (
            <header class="topbar">
              <a class="chrome-title" href={withBase("")}>
                <span class="chrome-mark">▧</span> {config.title}
              </a>
              <nav class="chrome-nav">
                {nav.map((l) => (
                  <a href={l.href} target={l.external ? '_blank' : undefined} rel={l.external ? 'noopener' : undefined}>
                    {l.label}{l.external && <span class="chrome-nav-ext">↗</span>}
                  </a>
                ))}
              </nav>
              {count && <span class="chrome-count">{count}</span>}
              <ThemeToggle />
              <KebabNav nav={nav} />
            </header>
          )
        }
        {
          chrome === 'rail' && (
            <aside class="rail">
              <span class="chrome-mark" aria-hidden="true">▧</span>
              <a class="rail-title" href={withBase("")}>{config.title}</a>
              <nav class="chrome-nav">
                {nav.map((l) => (
                  <a href={l.href} target={l.external ? '_blank' : undefined} rel={l.external ? 'noopener' : undefined}>
                    {l.label}
                  </a>
                ))}
              </nav>
              {count && <span class="chrome-count">{count}</span>}
              <ThemeToggle />
              <KebabNav nav={nav} />
            </aside>
          )
        }
        <div class="site-content" tabindex="-1">
          <slot />
          <div class="content-end">
            <span class="content-end-text">░▒▓ EOF ▓▒░</span>
          </div>
        </div>
      </div>
    </div>
    <script>
      // Keyboard scrolling works immediately without a click.
      document.querySelector<HTMLElement>('.site-content')?.focus({ preventScroll: true });
    </script>
  </body>
</html>
